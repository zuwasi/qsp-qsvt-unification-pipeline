Cell["Numerical check at a=0.6, d=5: Re P_5(0.6) equals T_5(0.6).", "Text",ExpressionUUID->"eb8e207b-c4aa-bd47-bbdc-fccdd668b9c4"],

Cell["\<\
d1 = 5;
phases0 = ConstantArray[0., d1 + 1];
u = QSPUnitary[phases0, 0.6];
{Re[u[[1, 1]]], ChebyshevT[d1, 0.6]}\
\>", "Input",ExpressionUUID->"dc5dc7c1-882a-5e40-a21f-685cb8b46109"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.07583999999999974`"}], ",", 
   RowBox[{"-", "0.07583999999999991`"}]}], "}"}]], "Output",ExpressionUUID->\
"4005190e-655c-fa4f-9dc4-edb443a2185b"],

Cell["\<\
The zero-phase QSP response traces the Chebyshev polynomial exactly.\
\>", "Text",ExpressionUUID->"1be91235-2f0f-a347-b7fe-5759108525f2"],

Cell["\<\
Plot[{QSPRealResponse[ConstantArray[0., 6], a], ChebyshevT[5, a]}, {a, -1, \
1},
 PlotLegends -> {\"Re P (QSP, zero phases)\", \"T_5(a)\"},
 PlotStyle -> {Thick, Dashed}, AxesLabel -> {\"a\", \"\"},
 PlotLabel -> \"Zero-phase QSP reproduces the Chebyshev polynomial\"]\
\>", "Input",ExpressionUUID->"5bfeb7e2-c07b-054d-80eb-75a4c68bf49d"],

