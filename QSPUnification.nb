Cell["\<\
Build a driven truncated-Fock Hamiltonian from the Quantum Framework's \
second-quantization operators, normalized so the spectral norm is \
\[LessEqual] 1.\
\>", "Text",ExpressionUUID->"6a44475b-bd32-c14f-ad3f-afb0e7e11949"],

Cell["\<\
H = BuildHamiltonian[];
Column[{
  \"dimension: \" <> ToString[H[\"Dimension\"]],
  \"eigenvalues: \" <> ToString[H[\"Eigenvalues\"]],
  \"spectral norm: \" <> ToString[Max[Abs[H[\"Eigenvalues\"]]]]}]\
\>", "Input",ExpressionUUID->"2a5e90d2-037f-a14c-8038-e06a14f0be5d"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"dimension: 4\"\>"},
    {"\<\"eigenvalues: {-0.705992, -0.310659, 0.166651, 0.85}\"\>"},
    {"\<\"spectral norm: 0.85\"\>"}
   },
   DefaultBaseStyle->"Column",
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Column"]], "Output",ExpressionUUID->"ef28e27c-22f9-fc4c-bfde-03357d9ce61e"],

Cell["\<\
Generate symmetric QSP phase angles so Re P approximates the (scaled) cos and \
sin targets.\
\>", "Text",ExpressionUUID->"54edb587-8672-7846-b7f3-819e1c7bf4d7"],

Cell["\<\
eta = 0.1; t = 2.0;
cosPh = FindQSPPhases[Function[x, (1 - eta) Cos[t x]], 12, \"Restarts\" -> \
6];
sinPh = FindQSPPhases[Function[x, (1 - eta) Sin[t x]], 13, \"Restarts\" -> \
6];
{\"cos max error\" -> cosPh[\"MaxError\"], \"sin max error\" -> \
sinPh[\"MaxError\"]}\
\>", "Input",ExpressionUUID->"306815bb-1f80-6d46-a515-d89246ae7449"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"cos max error\"\>", "\[Rule]", "2.7875298302948437`*^-7"}], ",", 
   RowBox[{"\<\"sin max error\"\>", "\[Rule]", "6.599418700403703`*^-8"}]}], 
  "}"}]], "Output",ExpressionUUID->"49fe38c3-f2fd-bd4b-aafb-b9bc5059deda"],

Cell["\<\
Reconstruct e^{-iHt} from the QSP cos/sin responses and compare to the exact \
matrix exponential.\
\>", "Text",ExpressionUUID->"8ac97004-3cff-f946-a069-f57b3857af03"],

Cell["\<\
recon = ReconstructEvolution[H[\"Matrix\"], t, cosPh[\"Phases\"], \
sinPh[\"Phases\"], eta];
{\"max abs error\" -> recon[\"MaxAbsError\"], \"overlap\" -> \
recon[\"NormalizedOverlap\"]}\
\>", "Input",ExpressionUUID->"e9204f5b-cd0d-6048-90b3-3152d726b72c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"max abs error\"\>", "\[Rule]", "1.3426129935073428`*^-7"}], ",", 
   RowBox[{"\<\"overlap\"\>", "\[Rule]", "0.9999999393206793`"}]}], 
  "}"}]], "Output",ExpressionUUID->"874154b8-5c8f-f841-898a-4830bbe4c7e9"],

Cell["Full numerical validation suite", "Section",ExpressionUUID->"0b929221-2346-1b4b-9d3f-4a505e773d57"],

Cell["\<\
Runs the package's complete validation suite (same checks exported by \
build_project.wls).\
\>", "Text",ExpressionUUID->"a23aab0b-d360-eb44-97ed-adb56951fce5"],

Cell["Dataset[RunValidationSuite[]]", "Input",ExpressionUUID->"2276dc07-2a76-bb46-998f-6cbd8b6c52ce"],

