Cell["Demo 2 \[LongDash] Hamiltonian simulation e^{-iHt}", "Section",ExpressionUUID->"87ee8856-ece0-6442-b0ec-fbcb78d30814"],

Cell["\<\
Jacobi\[Dash]Anger expansion approximates cos(t a) and sin(t a) by \
polynomials whose coefficients are Bessel functions (t=2, K=6).\
\>", "Text",ExpressionUUID->"0c0eac15-9675-0c4f-a24a-49c121e72a3e"],

Cell["\<\
cosData = JacobiAngerCos[2.0, 6];
sinData = JacobiAngerSin[2.0, 6];
{\"cos degree\" -> cosData[\"Degree\"], \"sin degree\" -> sinData[\"Degree\"]}\
\>", "Input",ExpressionUUID->"5df77c1d-b2fd-6740-bda1-c5ecba606702"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"cos degree\"\>", "\[Rule]", "12"}], ",", 
   RowBox[{"\<\"sin degree\"\>", "\[Rule]", "13"}]}], "}"}]], "Output",Express\
ionUUID->"0844cf8a-a29b-6f4e-82c0-fe924286f4a3"],

Cell["\<\
Plot[cosData[\"Function\"][x] - Cos[2.0 x], {x, -1, 1},
 PlotLabel -> \"Jacobi-Anger cos truncation error (t=2, K=6)\",
 AxesLabel -> {\"x\", \"error\"}]\
\>", "Input",ExpressionUUID->"3532bf65-d057-8240-a449-ea9cf10edb20"],

